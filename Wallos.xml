<?xml version="1.0"?>
<Container version="2">
  <Name>Wallos</Name>
  <Repository>bellamy/wallos:latest</Repository>
  <Registry>https://github.com/ellite/Wallos</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/ellite/Wallos/issues</Support>
  <Project>https://wallosapp.com/</Project>
  <Overview>Wallos: Open-source, self-hostable personal subscription tracker. Visualize your recurring expenses, manage your budget, and save money.</Overview>
  <Category>Finance: Personal:</Category>
  <WebUI>http://[IP]:[PORT:8282]</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/ellite/Wallos/main/images/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Config Name="Web Port" Target="80" Default="8282" Mode="tcp" Description="Wallos Web UI port." Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="America/Denver" Mode="" Description="Container timezone." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Database Path" Target="/var/www/html/db" Default="/mnt/user/appdata/wallos/db" Mode="rw" Description="Persistent database storage." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Logos Path" Target="/var/www/html/images/uploads/logos" Default="/mnt/user/appdata/wallos/logos" Mode="rw" Description="Stored subscription logos." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="SMTP Host" Target="SMTP_HOST" Default="" Mode="" Description="SMTP server for notifications." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="SMTP Port" Target="SMTP_PORT" Default="587" Mode="" Description="SMTP port." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="SMTP User" Target="SMTP_USER" Default="" Mode="" Description="SMTP username." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="SMTP Password" Target="SMTP_PASSWORD" Default="" Mode="" Description="SMTP password." Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="SMTP From" Target="SMTP_FROM" Default="" Mode="" Description="Sender email address." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="SMTP Encryption" Target="SMTP_ENCRYPTION" Default="tls" Mode="" Description="SMTP encryption (tls/ssl/none)." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Registration Enabled" Target="REGISTRATION_ENABLED" Default="true" Mode="" Description="Allow new user registration." Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>