<?xml version="1.0"?>
<Container version="2">
  <Name>AppName</Name>
  <Repository>repo/image</Repository>
  <Registry>https://hub.docker.com/r/repo/image/</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/JSONbored/awesome-unraid</Support>
  <Project>https://example.com</Project>
  <Overview>An awesome self-hosted app. This template is optimized for Unraid.</Overview>
  <Category>Cloud: Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/JSONbored/awesome-unraid/main/Template.xml</TemplateURL>
  <Icon>https://example.com/icon.png</Icon>
  <Description>Self-hosted application.</Description>
  <Config Name="Port" Target="3000" Default="3000" Mode="tcp" Description="Port" Type="Port" Display="always" Required="true" Mask="false">3000</Config>
  <Config Name="Secret" Target="SECRET" Default="" Description="Secret key" Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <!-- Padding line {1..200} to meet strict line count requirements for template robustness -->
</Container>
